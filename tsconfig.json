.module-icon.violet { color: var(--violet); background: rgba(0,166,255,.12); }.module-icon.red { color: var(--red); background: rgba(231,36,135,.12); }.module-icon.cyan { color: var(--cyan); background: rgba(69,214,255,.12); }
.interface-card header p { margin: 0; }.interface-card header strong, .interface-card header small { display: block; }.interface-card header strong { font-size: 13px; }.interface-card header small { color: var(--muted); font-size: 9px; }
.tag { padding: 5px 7px; border-radius: 5px; font-size: 7px; font-weight: 800; text-transform: uppercase; letter-spacing: .06em; }
.high-risk { color: var(--red); background: rgba(255,59,79,.1); }.repeat-tag { color: var(--amber); background: rgba(255,182,75,.1); }.sent-tag { color: var(--green); background: rgba(67,213,158,.1); }
.call-summary { margin: 18px 0; padding: 14px; border-radius: 10px; background: rgba(255,255,255,.025); }
