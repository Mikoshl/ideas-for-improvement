.phone-app p { margin: 0; }.phone-app strong, .phone-app small { display: block; }.phone-app strong { font-size: 8px; }.phone-app small { color: #777d88; font-size: 6px; }
.push-message { margin-top: 14px; padding: 12px; border-radius: 11px; background: white; box-shadow: 0 8px 22px rgba(20,26,35,.1); }
.push-message strong { font-size: 10px; }.push-message p { margin: 7px 0; color: #4b515c; font-size: 8px; line-height: 1.5; }.push-message span { color: #b12637; font-size: 7px; font-weight: 700; }
