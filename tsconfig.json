.case-action strong { display: block; margin-top: 4px; font-size: 9px; }.case-action button { padding: 8px 9px; border: 0; border-radius: 6px; background: var(--red); cursor: pointer; font-size: 7px; }
.no-duplicate { margin: 12px 0 0; color: var(--muted-2); text-align: center; font-size: 7px; }
.phone-shell { width: 84%; max-width: 270px; margin: 24px auto 16px; padding: 9px 12px 20px; border: 4px solid #252b37; border-radius: 25px; background: #e9ecf2; color: #151820; box-shadow: 0 20px 40px rgba(0,0,0,.3); }
.phone-top { display: flex; justify-content: space-between; color: #303541; font-size: 6px; }.phone-top i { width: 38px; height: 9px; border-radius: 6px; background: #11141a; }
.phone-app { margin-top: 16px; display: flex; align-items: center; gap: 7px; }
