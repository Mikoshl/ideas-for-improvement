.architecture-flow { margin-top: 34px; display: grid; grid-template-columns: 1fr 28px 1fr 28px 1fr 28px 1fr; align-items: stretch; }
.architecture-flow > article { min-height: 200px; padding: 20px; border: 1px solid var(--line); border-radius: 14px; background: rgba(10,13,15,.55); }
.architecture-flow > i { display: grid; place-items: center; color: var(--tele2-blue); font-style: normal; }
