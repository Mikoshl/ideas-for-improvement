.incident-icon { width: 26px; height: 26px; display: grid; place-items: center; border-radius: 7px; font-size: 9px; font-style: normal; }
.incident-icon.critical { color: var(--red); background: rgba(255,59,79,.1); }.incident-icon.warning { color: var(--amber); background: rgba(255,182,75,.1); }.incident-icon.info { color: var(--cyan); background: rgba(69,214,255,.1); }.incident-icon.success { color: var(--green); background: rgba(67,213,158,.1); }
.incident-feed strong, .incident-feed p, .incident-feed small { display: block; margin: 0; }
.incident-feed strong { font-size: 11px; }.incident-feed p { margin-top: 2px; color: #a1a8b5; font-size: 10px; }.incident-feed small { color: #8991a1; font-size: 9px; }
.incident-feed time { color: var(--muted); font-size: 9px; }
.view-all { width: 100%; margin-top: 12px; padding: 11px; border: 1px solid var(--line); border-radius: 8px; display: flex; justify-content: space-between; color: #aeb5c2; background: transparent; cursor: pointer; font-size: 10px; }
.demo-note { max-width: 900px; margin: 18px auto 0; color: #9199a9; font-size: 12px; text-align: center; }
.dashboard-build { margin-top: 56px; padding: 34px; border: 1px solid var(--line); border-radius: 20px; background: linear-gradient(145deg, rgba(0,166,255,.055), rgba(231,36,135,.025) 60%, rgba(255,255,255,.01)); }
.dashboard-build-heading { display: grid; grid-template-columns: 1.2fr .8fr; gap: 50px; align-items: end; }
