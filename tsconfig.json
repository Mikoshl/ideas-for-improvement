.owner { padding: 4px 6px; border-radius: 5px; color: var(--green); background: rgba(67,213,158,.08); font-size: 6px; }
.case-timeline { padding: 5px 0 5px 3px; }
.case-timeline > div { min-height: 70px; padding-left: 40px; position: relative; }
.case-timeline > div::after { content: ""; position: absolute; left: 13px; top: 27px; bottom: -6px; width: 1px; background: var(--line); }
.case-timeline > div:last-child::after { display: none; }
.case-timeline i { position: absolute; left: 0; top: 0; width: 27px; height: 27px; display: grid; place-items: center; border: 1px solid var(--line); border-radius: 50%; color: var(--muted); background: var(--panel); font-size: 8px; font-style: normal; }
.case-timeline .active i { color: white; border-color: var(--red); background: var(--red); box-shadow: 0 0 18px rgba(255,59,79,.28); }
.case-timeline p { margin: 0; }.case-timeline strong, .case-timeline small { display: block; }.case-timeline strong { font-size: 12px; }.case-timeline small { color: var(--muted); font-size: 10px; }
