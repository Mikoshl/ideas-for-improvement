.push-tabs button.active { color: white; border-color: rgba(69,214,255,.25); background: rgba(69,214,255,.08); }

.cases { border-top: 1px solid var(--line); }
.case-feature { min-height: 360px; display: grid; grid-template-columns: .8fr 1.05fr 1.3fr; border: 1px solid var(--line); border-radius: 20px; overflow: hidden; background: linear-gradient(140deg, rgba(255,255,255,.045), rgba(255,255,255,.008)); }
.case-feature > div { padding: 34px; border-right: 1px solid var(--line); }.case-feature > div:last-child { border: 0; }
.case-company { display: flex; flex-direction: column; }.company-index { color: var(--red); font-size: 10px; font-weight: 800; }.case-company > strong { margin-top: 72px; font-size: 32px; letter-spacing: -.04em; }.case-company p { color: var(--muted); font-size: 13px; }.case-company a { margin-top: auto; color: var(--muted); font-size: 11px; }.case-company a:hover, .case-list a:hover { color: white; }
.case-result > span, .case-use > span { color: var(--muted); font-size: 10px; font-weight: 750; letter-spacing: .08em; }.case-result > div { margin-top: 44px; }.case-result > div + div { margin-top: 24px; }.case-result strong { display: block; font-size: 46px; line-height: 1; letter-spacing: -.06em; }.case-result strong i { margin: 0 14px; color: var(--red); font-size: 23px; font-style: normal; }.case-result p { margin: 7px 0 0; color: var(--muted); font-size: 12px; }
.case-use { display: flex; flex-direction: column; }.case-use > p { margin-top: 70px; color: #c0c5cf; font-size: 18px; line-height: 1.65; }.case-use > div { display: flex; flex-wrap: wrap; gap: 5px; margin-top: auto; }.case-use b { padding: 6px 8px; border-radius: 6px; color: var(--violet); background: rgba(0,166,255,.09); font-size: 9px; }
.case-list { margin-top: 12px; border: 1px solid var(--line); border-radius: 16px; overflow: hidden; }.case-list article { min-height: 165px; padding: 24px; display: grid; grid-template-columns: 60px 1.3fr 1fr .65fr; gap: 24px; align-items: center; border-bottom: 1px solid var(--line); transition: background .2s; }.case-list article:last-child { border-bottom: 0; }.case-list article:hover { background: rgba(255,255,255,.025); }.case-number { color: var(--muted); font-size: 11px; }.case-list article span { color: var(--muted); font-size: 9px; letter-spacing: .08em; font-weight: 750; }.case-list h3 { margin: 5px 0; font-size: 19px; }.case-list p { margin: 0; color: #aeb5c2; font-size: 12px; line-height: 1.6; }.case-metrics { display: flex; gap: 32px; }.case-metrics strong { font-size: 24px; letter-spacing: -.04em; }.case-metrics small { display: block; margin-top: 4px; color: var(--muted); font-size: 9px; letter-spacing: 0; font-weight: 500; }.case-list article > div:last-child { display: flex; flex-direction: column; gap: 15px; }.case-list article > div:last-child b { color: var(--red); font-size: 10px; }.case-list a { color: var(--muted); font-size: 10px; }
.source-note { max-width: 900px; margin: 18px 0 0 auto; color: var(--muted-2); font-size: 10px; text-align: right; }

.roadmap { border-top: 1px solid var(--line); }
.roadmap-track { display: grid; grid-template-columns: repeat(5, 1fr); gap: 0; position: relative; }
.roadmap-track::before { content: ""; position: absolute; left: 10%; right: 10%; top: 50px; height: 1px; background: var(--line); }
.roadmap-track article { min-height: 300px; padding: 20px; position: relative; }.roadmap-track span { color: var(--muted); font-size: 10px; font-weight: 750; letter-spacing: .08em; }.roadmap-track i { width: 15px; height: 15px; margin: 20px 0 40px; display: block; border: 3px solid var(--bg); border-radius: 50%; background: #343b4b; box-shadow: 0 0 0 1px var(--line-strong); position: relative; z-index: 2; }.roadmap-track .active i { background: var(--red); box-shadow: 0 0 22px rgba(231,36,135,.5); }.roadmap-track h3 { min-height: 48px; margin-bottom: 10px; font-size: 18px; }.roadmap-track p { color: #aeb5c2; font-size: 12px; line-height: 1.65; }.roadmap-track small { display: block; margin-top: 23px; color: var(--muted); font-size: 9px; letter-spacing: .07em; }
.security-panel { margin-top: 60px; padding: 30px; border: 1px solid rgba(0,166,255,.2); border-radius: 18px; display: grid; grid-template-columns: 1.1fr 1.4fr 1fr; gap: 30px; align-items: center; background: linear-gradient(120deg, rgba(0,166,255,.07), rgba(255,255,255,.012)); }.security-panel > div { display: flex; align-items: center; gap: 15px; }.shield-icon { width: 50px; height: 50px; display: grid; place-items: center; border: 1px solid rgba(0,166,255,.25); border-radius: 14px; color: var(--violet); font-size: 24px; }.security-panel p { margin: 0; }.security-panel p strong { display: block; margin-top: 6px; font-size: 14px; }.security-panel ul { display: flex; flex-wrap: wrap; gap: 6px; margin: 0; padding: 0; list-style: none; }.security-panel li { padding: 7px 9px; border: 1px solid var(--line); border-radius: 7px; color: var(--muted); font-size: 10px; }.security-panel blockquote { margin: 0; padding-left: 16px; border-left: 2px solid var(--violet); color: #bbc0cc; font-size: 12px; font-style: italic; }
.public-safety { margin-top: 16px; padding: 30px; border: 1px solid rgba(231,36,135,.18); border-radius: 18px; background: rgba(231,36,135,.025); }
.public-safety-heading { display: grid; grid-template-columns: 1fr 1fr; gap: 18px 48px; }
.public-safety-heading .eyebrow { grid-column: 1 / -1; color: var(--altel-magenta); }
.public-safety-heading h3 { margin: 0; font-size: 28px; letter-spacing: -.035em; }
.public-safety-heading p { margin: 0; color: #aeb5c2; font-size: 13px; line-height: 1.7; }
.public-safety-grid { margin-top: 28px; display: grid; grid-template-columns: repeat(4, 1fr); gap: 9px; }
.public-safety-grid article { min-height: 160px; padding: 18px; border: 1px solid var(--line); border-radius: 12px; background: rgba(255,255,255,.015); }
.public-safety-grid strong { display: block; font-size: 13px; }
.public-safety-grid p { margin: 18px 0 0; color: #979fad; font-size: 11px; line-height: 1.55; }

.summary { padding-bottom: 70px; }
.summary-card { min-height: 470px; padding: 60px; display: grid; grid-template-columns: 1.05fr .95fr; gap: 90px; border: 1px solid rgba(231,36,135,.2); border-radius: 24px; background: radial-gradient(circle at 15% 30%, rgba(231,36,135,.12), transparent 34%), linear-gradient(140deg, #14141c, #0c0f17); box-shadow: var(--shadow); }.summary-copy h2 { margin: 26px 0 20px; font-size: clamp(45px, 5vw, 76px); line-height: 1; letter-spacing: -.06em; }.summary-copy > p { max-width: 650px; color: #abb1bf; font-size: 16px; line-height: 1.7; }.summary-actions { display: flex; gap: 10px; margin-top: 36px; }.summary-points { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }.summary-points article { min-height: 150px; padding: 19px; border: 1px solid var(--line); border-radius: 13px; background: rgba(255,255,255,.018); }.summary-points span { color: var(--red); font-size: 8px; font-weight: 900; }.summary-points p { margin: 36px 0 0; color: var(--muted); font-size: 10px; line-height: 1.6; }.summary-points strong { display: block; margin-bottom: 4px; color: white; font-size: 13px; }
.final-statement { padding: 150px 0 80px; text-align: center; }.final-statement > span { color: var(--red); font-size: 9px; font-weight: 900; letter-spacing: .2em; }.final-statement p { margin: 28px auto 0; font-size: clamp(42px, 5.5vw, 82px); line-height: 1.08; letter-spacing: -.06em; font-weight: 700; }
.site-footer { min-height: 125px; padding: 24px 0; border-top: 1px solid var(--line); display: flex; align-items: center; justify-content: space-between; gap: 26px; color: var(--muted); font-size: 11px; }.site-footer .brand { min-width: 250px; }.site-footer a { color: var(--muted); }
.owner-mark { margin: 0; padding: 10px 14px; border: 1px solid rgba(231,36,135,.2); border-radius: 10px; background: rgba(231,36,135,.04); }
.owner-mark strong, .owner-mark span { display: block; }
.owner-mark strong { color: var(--red-bright); font-size: 10px; text-transform: uppercase; letter-spacing: .07em; }
.owner-mark span { margin-top: 3px; color: #b3bac7; font-size: 11px; }

.solution-dialog { width: min(980px, calc(100% - 32px)); max-height: 92vh; padding: 46px; border: 1px solid var(--line-strong); border-radius: 20px; color: white; background: #121517; box-shadow: 0 40px 100px rgba(0,0,0,.6); }.solution-dialog::backdrop { background: rgba(0,0,0,.78); backdrop-filter: blur(10px); }.dialog-close { position: absolute; right: 18px; top: 16px; width: 38px; height: 38px; border: 1px solid var(--line); border-radius: 50%; background: transparent; color: var(--muted); cursor: pointer; font-size: 22px; }.dialog-index { color: var(--altel-magenta); font-size: 12px; font-weight: 800; }.solution-dialog h2 { margin: 18px 0 12px; font-size: 48px; letter-spacing: -.045em; }.dialog-lead { max-width: 850px; color: #c0c6d0; font-size: 17px; line-height: 1.7; }.dialog-estimate { margin-top: 28px; display: grid; grid-template-columns: repeat(3, 1fr); border: 1px solid var(--line); border-radius: 13px; overflow: hidden; }.dialog-estimate article { padding: 17px; border-right: 1px solid var(--line); }.dialog-estimate article:last-child { border: 0; }.dialog-estimate span { display: block; color: #8f98a8; font-size: 9px; letter-spacing: .08em; }.dialog-estimate strong { display: block; margin-top: 8px; font-size: 19px; }.dialog-estimate article:nth-child(3) strong { color: var(--tele2-blue); }.dialog-columns, .dialog-tech { margin-top: 16px; display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }.dialog-columns > div, .dialog-tech > div { padding: 19px; border: 1px solid var(--line); border-radius: 12px; }.dialog-columns span, .dialog-tech span, .dialog-effect > span { color: #8f98a8; font-size: 10px; font-weight: 750; letter-spacing: .08em; }.dialog-columns ul, .dialog-tech ul { margin: 14px 0 0; padding-left: 18px; color: #abb3c0; font-size: 13px; line-height: 1.72; }.dialog-tech p { margin: 14px 0 0; color: #abb3c0; font-size: 13px; line-height: 1.7; }.dialog-effect { margin-top: 16px; padding: 20px; border: 1px solid rgba(0,166,255,.2); border-radius: 12px; background: rgba(0,166,255,.04); }.dialog-effect > p { margin: 8px 0 0; color: #d5dae3; font-size: 15px; line-height: 1.6; }.dialog-metrics { margin-top: 16px; display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }.dialog-metrics article { padding: 13px; border-radius: 9px; background: rgba(255,255,255,.035); }.dialog-metrics strong, .dialog-metrics span { display: block; }.dialog-metrics strong { color: var(--altel-magenta); font-size: 20px; }.dialog-metrics span { margin-top: 4px; color: #aab2bf; font-size: 10px; line-height: 1.35; }.estimate-disclaimer { margin: 14px 0 0; color: #798291; font-size: 10px; line-height: 1.55; }

.reveal { opacity: 0; transform: translateY(22px); transition: opacity .7s ease, transform .7s ease; }.reveal.visible { opacity: 1; transform: none; }.reveal-delay-1 { transition-delay: .12s; }.reveal-delay-2 { transition-delay: .22s; }

@media (max-width: 1180px) {
  .main-nav { display: none; }
  .site-header { justify-content: space-between; }
  .hero { grid-template-columns: 1fr; padding-top: 100px; }
  .hero-copy { max-width: 850px; }
  .hero-visual { margin-top: 70px; }
  .hero-statement { padding-left: 0; }
  .section-heading { grid-template-columns: 140px 1fr; }.section-heading > p { grid-column: 2; max-width: 600px; }
  .repeat-chain { grid-template-columns: repeat(3, 1fr); }.repeat-chain article:nth-child(3) { border-right: 0; }.repeat-chain article:nth-child(-n+3) { border-bottom: 1px solid var(--line); }
  .solutions-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }.solution-card.featured { grid-column: span 1; }
  .dashboard-body { grid-template-columns: 180px 1fr; }.incident-feed { grid-column: 1 / -1; display: grid; grid-template-columns: repeat(4, 1fr); border-left: 0; border-top: 1px solid var(--line); }.incident-title, .view-all { grid-column: 1 / -1; }
  .interface-grid { grid-template-columns: 1fr 1fr; }.push-card { grid-column: 1 / -1; min-height: auto; }.phone-shell { max-width: 330px; }
  .case-feature { grid-template-columns: .75fr 1fr 1.15fr; }.case-list article { grid-template-columns: 45px 1.25fr .9fr .6fr; }
  .security-panel { grid-template-columns: 1fr 1.3fr; }.security-panel blockquote { grid-column: 1 / -1; }
}

@media (max-width: 820px) {
  .section-shell { width: min(100% - 32px, var(--max)); }
  .site-header { width: calc(100% - 24px); height: 66px; top: 8px; margin-top: 8px; }
  .brand { min-width: auto; }.site-header .brand-copy small { display: none; }.header-cta { display: none; }.menu-toggle { width: 40px; height: 40px; display: grid; place-content: center; gap: 6px; }.menu-toggle span { width: 20px; height: 1px; background: white; }
  .main-nav { position: absolute; left: 0; right: 0; top: 74px; padding: 12px; border: 1px solid var(--line); border-radius: 14px; background: rgba(10,13,20,.97); display: none; flex-direction: column; align-items: stretch; }.main-nav.open { display: flex; }.main-nav a { padding: 12px; }
  .hero { min-height: auto; padding: 85px 0 50px; overflow: clip; }.hero h1 { font-size: clamp(46px, 12vw, 66px); }.hero-lead { font-size: 17px; }.hero-proof { gap: 20px; justify-content: space-between; }.hero-proof div { display: block; }.hero-proof span { margin-top: 6px; display: block; }
  .screen-grid { grid-template-columns: 1fr; }.screen-feed { display: none; }.screen-map { min-height: 430px; border-right: 0; }.floating-chip { display: none; }.hero-statement { margin-top: 70px; grid-template-columns: 1fr; gap: 10px; }.hero-statement p { font-size: 30px; }
  .proposal-check-grid { grid-template-columns: 1fr; }.proposal-check-grid article { min-height: 140px; border-right: 0; border-bottom: 1px solid var(--line); }.proposal-check-grid article:last-child { border-bottom: 0; }
  .problem, .solutions, .control, .interfaces, .cases, .roadmap, .summary { padding: 95px 0; }
  .section-heading, .section-heading.compact { grid-template-columns: 1fr; gap: 18px; margin-bottom: 48px; }.section-heading > p { grid-column: 1; }.section-heading h2 { font-size: 46px; }
  .repeat-chain { grid-template-columns: 1fr 1fr; }.repeat-chain article { border-right: 1px solid var(--line) !important; border-bottom: 1px solid var(--line); }.repeat-chain article:nth-child(even) { border-right: 0 !important; }.repeat-chain article:nth-last-child(-n+2) { border-bottom: 0; }
  .solutions-grid { grid-template-columns: 1fr; }.ecosystem-strip { justify-content: flex-start; }
  .control { padding-inline: 16px; }.dashboard-kpis { grid-template-columns: 1fr 1fr; }.dashboard-kpis article:nth-child(2) { border-right: 0; }.dashboard-kpis article:nth-child(-n+2) { border-bottom: 1px solid var(--line); }.dashboard-body { grid-template-columns: 1fr; }.dashboard-filters { border-right: 0; border-bottom: 1px solid var(--line); }.map-filter-list { grid-template-columns: 1fr 1fr; }.period-caption, .period-switch { display: none; }.interactive-map { min-height: 560px; }.interactive-map svg { margin-top: 80px; }.incident-feed { grid-template-columns: 1fr 1fr; }
  .dashboard-build { padding: 24px; }.dashboard-build-heading { grid-template-columns: 1fr; gap: 18px; }.architecture-flow { grid-template-columns: 1fr; gap: 8px; }.architecture-flow > i { transform: rotate(90deg); }.architecture-flow > article { min-height: 165px; }.build-facts { grid-template-columns: 1fr 1fr; }
  .interface-grid { grid-template-columns: 1fr; }.push-card { grid-column: auto; }.interface-card { min-height: auto; }
  .case-feature { grid-template-columns: 1fr; }.case-feature > div { border-right: 0; border-bottom: 1px solid var(--line); }.case-company > strong, .case-use > p { margin-top: 34px; }.case-company a { margin-top: 22px; }.case-list article { grid-template-columns: 40px 1fr; }.case-metrics, .case-list article > div:last-child { grid-column: 2; }
  .roadmap-track { grid-template-columns: 1fr 1fr; }.roadmap-track::before { display: none; }.roadmap-track article { min-height: 230px; }.roadmap-track i { margin-bottom: 24px; }.security-panel { grid-template-columns: 1fr; }.security-panel blockquote { grid-column: auto; }
  .public-safety-heading { grid-template-columns: 1fr; }.public-safety-heading .eyebrow { grid-column: auto; }.public-safety-grid { grid-template-columns: 1fr 1fr; }
  .summary-card { padding: 35px; grid-template-columns: 1fr; gap: 50px; }.summary-copy h2 { font-size: 52px; }.dialog-estimate, .dialog-metrics { grid-template-columns: 1fr; }.dialog-estimate article { border-right: 0; border-bottom: 1px solid var(--line); }.dialog-estimate article:last-child { border-bottom: 0; }
  .site-footer { gap: 16px; flex-wrap: wrap; }.site-footer > p { width: 100%; }.site-footer .owner-mark { order: 2; }.site-footer > p:not(.owner-mark) { order: 3; }
}

@media (max-width: 520px) {
  .section-shell { width: calc(100% - 24px); }
  .hero h1 { font-size: 48px; }.hero-actions .button { width: 100%; }.hero-proof { margin-top: 42px; }.screen-map { min-height: 320px; padding: 12px; }.screen-map svg { margin-top: 38px; }.map-tooltip { left: 32%; bottom: 28px; transform: scale(.85); }.screen-topbar .secure-badge { display: none; }
  .section-heading h2 { font-size: 38px; }.repeat-chain { grid-template-columns: 1fr; }.repeat-chain article { min-height: 190px; border-right: 0 !important; }.repeat-chain article:nth-last-child(2) { border-bottom: 1px solid var(--line); }.step-icon { margin-top: 28px; }
  .solutions-grid { grid-template-columns: 1fr; }.solution-card { min-height: 440px; padding: 22px; }.solution-toolbar { overflow-x: auto; flex-wrap: nowrap; }.filter-button { white-space: nowrap; }
  .dashboard-actions .status-online { display: none; }.dashboard-kpis { grid-template-columns: 1fr 1fr; }.dashboard-kpis article { padding: 15px; }.dashboard-kpis strong { font-size: 21px; }.map-filter-list { grid-template-columns: 1fr; }.interactive-map { min-height: 430px; }.region-card { left: 16px; right: 16px; width: auto; bottom: 16px; }.incident-feed { grid-template-columns: 1fr; }
  .complaint-point text { display: none; }.build-facts { grid-template-columns: 1fr; }.dashboard-build-heading h3 { font-size: 25px; }
  .case-feature > div { padding: 24px; }.case-result strong { font-size: 38px; }.case-use > p { font-size: 16px; }.case-list article { padding: 18px 14px; gap: 12px; }.case-metrics { flex-wrap: wrap; gap: 16px; }
  .roadmap-track { grid-template-columns: 1fr; }.roadmap-track article { min-height: auto; padding-bottom: 45px; }.security-panel { padding: 22px; }.public-safety { padding: 22px; }.public-safety-grid { grid-template-columns: 1fr; }.summary-card { padding: 26px 20px; }.summary-copy h2 { font-size: 42px; }.summary-actions { flex-direction: column; }.summary-points { grid-template-columns: 1fr; }.final-statement { padding-top: 110px; }.solution-dialog { padding: 36px 22px 24px; }.solution-dialog h2 { font-size: 36px; }.dialog-columns, .dialog-tech { grid-template-columns: 1fr; }
}

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after { scroll-behavior: auto !important; animation-duration: .01ms !important; animation-iteration-count: 1 !important; transition-duration: .01ms !important; }
  .reveal { opacity: 1; transform: none; }
}

@media print {
  :root { --bg: white; --text: #111; --muted: #555; --line: #ddd; }
  body { background: white; color: #111; }
  .site-header, .hero-visual, .button, .solution-toolbar, .dashboard-actions, .push-tabs, .site-footer { display: none !important; }
  .section-shell { width: 100%; }
  .hero { min-height: auto; display: block; padding: 30px 0; }.hero-copy { max-width: none; }.hero h1 { font-size: 54px; }.hero-statement { margin-top: 45px; }
  .problem, .solutions, .control, .interfaces, .cases, .roadmap, .summary { padding: 45px 0; break-inside: avoid; }
  .reveal { opacity: 1; transform: none; }
  .solution-card, .repeat-chain, .dashboard, .interface-card, .case-feature, .case-list, .security-panel, .summary-card { border-color: #ccc; background: white; box-shadow: none; color: #111; }
  .solutions-grid { grid-template-columns: repeat(2, 1fr); }.solution-card { min-height: 230px; }
  .dashboard { display: none; }
}
