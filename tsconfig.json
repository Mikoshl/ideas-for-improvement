.region-card > strong small { color: var(--muted); font-size: 10px; font-weight: 500; }
.region-card dl { margin: 0; display: grid; grid-template-columns: repeat(3, 1fr); border: 1px solid var(--line); border-radius: 7px; }
.region-card dl div { padding: 7px; border-right: 1px solid var(--line); }
